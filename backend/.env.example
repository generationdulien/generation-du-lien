# Backend Environment Variables

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/generation_lien"

# Server
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRATION=24h

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Emails (Resend)
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=noreply@generation-lien.fr
EMAIL_FROM_NAME="Génération du Lien"

# CAPTCHA (hCaptcha)
HCAPTCHA_SECRET=your_hcaptcha_secret_key_here

# Logging
LOG_LEVEL=debug

# Database Migrations
DATABASE_MIGRATE_ON_START=true
DATABASE_SEED_ON_START=true

# Feature Flags
FEATURE_COMMENTS=false
FEATURE_CONTRIBUTIONS=false
